<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <TextView android:id="@+id/log_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="원하는 콘서트를 선택하세요." android:textSize="16sp" android:gravity="center" android:layout_marginBottom="20dp"/>
    <LinearLayout android:id="@+id/screen_concerts" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible">
        <Button android:id="@+id/card_post" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="포스트말론 내한공연" />
        <Button android:id="@+id/card_justin" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="저스틴 비버 월드투어" />
        <Button android:id="@+id/card_weeknd" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="위켄드 아시아투어" />
        <Button android:id="@+id/card_hero" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="임영웅 전국투어(대구)" />
    </LinearLayout>
    <TextView android:id="@+id/tv_selected_concert" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#000000" android:gravity="center" android:layout_marginVertical="10dp"/>
    <LinearLayout android:id="@+id/screen_sliding" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
        <RelativeLayout android:id="@+id/slide_track" android:layout_width="match_parent" android:layout_height="60dp" android:background="#EEEEEE">
            <View android:id="@+id/slide_thumb" android:layout_width="60dp" android:layout_height="60dp" android:background="#4CAF50"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_waiting" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" android:gravity="center" android:padding="24dp">
        <TextView android:id="@+id/tv_queue_status" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="대기열 진입 중..." android:textSize="18sp" android:textStyle="bold" android:gravity="center"/>
        <TextView android:id="@+id/tv_queue_eta" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textSize="14sp" android:gravity="center" android:layout_marginTop="8dp"/>
        <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp"/>
        <Button android:id="@+id/btn_cancel_queue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="대기 취소" android:layout_marginTop="16dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_sections" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
        <Button android:id="@+id/btn_sectionA" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="A 구역" />
        <Button android:id="@+id/btn_sectionB" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="B 구역" />
        <Button android:id="@+id/btn_sectionC" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="C 구역" />
        <Button android:id="@+id/btn_sectionD" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="D 구역" />
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_seats" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical" android:visibility="gone">
        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:paddingTop="12dp" android:paddingBottom="12dp" android:clipToPadding="false" android:fillViewport="true">
            <GridLayout android:id="@+id/grid_seats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:columnCount="10"/>
        </ScrollView>
        <Button android:id="@+id/btn_purchase" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="결제 요청 (CAS)" android:layout_marginTop="8dp" android:visibility="gone"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_payment" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
        <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="결제 요청 중입니다. 잠시만 기다려주세요..." android:gravity="center" android:layout_marginTop="10dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_success" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" android:gravity="center" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎉" android:textSize="64sp" android:gravity="center"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="예매 성공!" android:textSize="28sp" android:textStyle="bold" android:textColor="#2E7D32" android:gravity="center" android:layout_marginTop="8dp"/>
        <TextView android:id="@+id/tv_success_concert" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textSize="16sp" android:gravity="center" android:layout_marginTop="24dp"/>
        <TextView android:id="@+id/tv_success_seat" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textSize="20sp" android:textStyle="bold" android:textColor="#E91E63" android:gravity="center" android:layout_marginTop="8dp"/>
        <Button android:id="@+id/btn_success_ok" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="확인" android:layout_marginTop="32dp"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/screen_soldout" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone" android:gravity="center" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎫" android:textSize="64sp" android:gravity="center"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="매진" android:textSize="40sp" android:textStyle="bold" android:textColor="#D32F2F" android:gravity="center" android:layout_marginTop="16dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="모든 좌석이 매진되었습니다" android:textSize="16sp" android:gravity="center" android:layout_marginTop="8dp"/>
        <TextView android:id="@+id/tv_soldout_concert" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_marginTop="24dp"/>
        <Button android:id="@+id/btn_soldout_ok" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="다른 콘서트 보기" android:layout_marginTop="32dp"/>
    </LinearLayout>
</LinearLayout>
